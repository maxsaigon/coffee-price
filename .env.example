# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
FMP_API_KEY=your_fmp_api_key_here


# Scraper Settings
SCRAPER_TIMEOUT=15
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=2.0

# Timezone
TIMEZONE=Asia/Ho_Chi_Minh

# Scheduling (UTC times for GitHub Actions)
MORNING_SCHEDULE=01:00  # 8AM Vietnam = 1AM UTC
EVENING_SCHEDULE=08:00  # 3PM Vietnam = 8AM UTC

# Data Storage
DATABASE_PATH=coffee_prices.db
LOG_LEVEL=INFO
LOG_FILE=coffee_tracker.log

# Exchange Rate (VND per USD)
USD_TO_VND_RATE=26000

# Gold validation
GOLD_MAX_STALE_MINUTES=30
GOLD_XAU_MAX_SOURCE_DIFF_PERCENT=1.0
